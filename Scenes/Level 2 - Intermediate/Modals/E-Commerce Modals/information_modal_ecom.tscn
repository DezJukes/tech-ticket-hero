[node name="ProblemBody" type="Label" parent="BackgroundOverlay/Center/MainBox/Padding/VerticalFlow/SplitBody/ProblemCard/ProblemPadding/ProblemTextFlow" unique_id=858768548]
layout_mode = 2
theme_override_colors/font_color = Color(0, 0, 0, 1)
theme_override_constants/line_spacing = 5
theme_override_fonts/font = ExtResource("3_pd54y")
text = "Our digital shop is dangerously exposed! While customers can look at products, the site is being overwhelmed by automated bot attacks that are slowing it down for real shoppers. There is no longer a way to verify a customer's session or confirm if they are authorized to make purchases. Most critically, customers are stuck at their carts because the system cannot securely communicate with external banks, and there is no way to dispatch events to the warehouse once an order is placed."
autowrap_mode = 3

