[node name="ProblemBody" type="Label" parent="BackgroundOverlay/Center/MainBox/Padding/VerticalFlow/SplitBody/ProblemCard/ProblemPadding/ProblemTextFlow" unique_id=1362763254]
layout_mode = 2
theme_override_colors/font_color = Color(0, 0, 0, 1)
theme_override_constants/line_spacing = 5
theme_override_fonts/font = ExtResource("3_3ir1j")
text = "The library's digital strategy is failing its physical location. The physical touchpoints for students on campus are gone. 

Currently, there is no way for a student to walk up and scan their physical ID or a book's barcode. 

Even worse, while students can view archives, the system has no way to log permanent borrow transactions or ensure that a book's status is updated with strict data integrity."
autowrap_mode = 3

